# .env - Configuration API AGHeal
# Copier ce fichier et remplir les valeurs réelles

# ── Base de données ──────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=agheal
DB_USER=root
DB_PASSWORD=VOTRE_MOT_DE_PASSE_ICI

# ── JWT ─────────────────────────────────────────
JWT_SECRET=CHANGEZ_MOI_PAR_UNE_LONGUE_CLE_SECRETE_ALEATOIRE
JWT_EXPIRATION=86400

# ── URLs ─────────────────────────────────────────
API_URL=http://localhost:8081/agheal-api/public
FRONTEND_URL=http://localhost:5173

# ── SMTP (PHPMailer) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_app_password_gmail
SMTP_FROM_EMAIL=votre.email@gmail.com
SMTP_FROM_NAME=AGHeal

# ── Admin ────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
